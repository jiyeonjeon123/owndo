<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>owndo° — Thermal Diagnostic</title>
<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
<style>
  :root {
    --primary:    #7A2624;
    --secondary:  #954E2B;
    --tertiary:   #4E560F;
    --accent:     #909A30;
    --ink:        #1f1d1b;
    --ink-soft:   #4a443e;
    --ink-faint:  #8a847a;
    --line:       #e0dcd4;
    --rule:       rgba(31, 29, 27, 0.10);
    --cold:       #3a5a7a;
    --cold-soft:  #7a96b4;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    background: #ffffff;
    color: var(--ink);
    font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    font-weight: 400;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  header {
    padding: 28px 48px 20px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--rule);
  }

  .brand {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--primary);
  }
  .brand sup { font-size: 0.5em; vertical-align: super; margin-left: 1px; }

  .meta {
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .patient-bar {
    max-width: 1400px;
    margin: 0 auto;
    padding: 28px 48px 24px;
    display: grid;
    grid-template-columns: auto 1fr 1fr 1fr;
    gap: 24px;
    align-items: end;
    border-bottom: 1px solid var(--rule);
  }

  .patient-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--accent);
    text-transform: uppercase;
    padding-bottom: 8px;
    line-height: 1.4;
  }

  .patient-field { display: flex; flex-direction: column; }
  .patient-field label {
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-faint);
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }
  .patient-field input,
  .patient-field select {
    border: none;
    border-bottom: 1px solid var(--ink);
    background: transparent;
    padding: 6px 0;
    font-family: inherit;
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    outline: none;
    width: 100%;
    border-radius: 0;
    -webkit-appearance: none;
            appearance: none;
  }
  .patient-field input:focus,
  .patient-field select:focus { border-color: var(--primary); }
  .patient-field input::placeholder { color: var(--ink-faint); font-weight: 400; }

  .patient-field.gender { position: relative; }
  .patient-field.gender::after {
    content: '⌄';
    position: absolute;
    right: 0;
    bottom: 8px;
    font-size: 14px;
    color: var(--ink-faint);
    pointer-events: none;
  }

  .console {
    max-width: 1400px;
    margin: 0 auto;
    padding: 56px 48px 80px;
    display: grid;
    grid-template-columns: 380px 1fr 380px;
    gap: 48px;
    align-items: start;
  }

  @media (max-width: 1100px) {
    .console { grid-template-columns: 1fr; padding: 40px 24px; gap: 32px; }
    .patient-bar { grid-template-columns: 1fr 1fr; padding: 24px; }
  }

  .panel {
    border: 1px solid var(--rule);
    padding: 32px 28px;
  }

  .panel-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .panel-title {
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--rule);
    color: var(--ink);
  }

  .input-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 22px;
  }

  .input-group { display: flex; flex-direction: column; }
  .input-group label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--tertiary);
    margin-bottom: 4px;
  }
  .input-group .desc {
    font-size: 11px;
    font-weight: 400;
    color: var(--ink-faint);
    margin-bottom: 8px;
  }

  .input-wrap {
    position: relative;
    display: flex;
    align-items: baseline;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 4px;
  }

  .input-wrap input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 24px;
    font-weight: 500;
    color: var(--ink);
    width: 100%;
    outline: none;
    padding: 4px 0;
    letter-spacing: -0.02em;
  }
  .input-wrap input::-webkit-outer-spin-button,
  .input-wrap input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .input-wrap input[type=number] { -moz-appearance: textfield; }

  .input-wrap .unit {
    font-size: 14px;
    font-weight: 400;
    color: var(--ink-faint);
    margin-left: 4px;
  }

  .slider-wrap { margin-top: 8px; }
  input[type="range"] {
    -webkit-appearance: none;
    width: 100%;
    height: 1px;
    background: var(--line);
    outline: none;
  }
  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 12px;
    background: var(--primary);
    cursor: pointer;
    border-radius: 50%;
  }
  input[type="range"]::-moz-range-thumb {
    width: 12px;
    height: 12px;
    background: var(--primary);
    cursor: pointer;
    border-radius: 50%;
    border: none;
  }

  .presets { margin-top: 28px; padding-top: 24px; border-top: 1px solid var(--rule); }
  .preset-btns { display: flex; flex-direction: column; gap: 8px; margin-top: 12px; }
  .preset-btn {
    background: transparent;
    border: 1px solid var(--rule);
    padding: 12px 16px;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-soft);
    transition: all 0.25s ease;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: 0;
  }
  .preset-btn:hover { border-color: var(--accent); color: var(--ink); }
  .preset-btn .arrow { color: var(--accent); font-weight: 600; }

  .viz {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 0;
  }

  .viz-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: var(--ink-faint);
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .stage {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 1;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stage::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid var(--line);
    border-radius: 50%;
    opacity: 0.7;
  }
  .stage::after {
    content: 'e = 0  ·  Original Degree°';
    position: absolute;
    bottom: -28px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  #ellipse-svg {
    width: 100%;
    height: 100%;
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .equation {
    margin-top: 64px;
    padding: 24px 28px;
    border: 1px solid var(--rule);
    font-family: 'JetBrains Mono', 'Pretendard Variable', Pretendard, monospace;
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 2;
    width: 100%;
    max-width: 520px;
  }
  .equation .var { color: var(--secondary); font-weight: 500; }
  .equation .num { color: var(--primary); font-weight: 600; }
  .equation .lbl {
    display: inline-block;
    width: 100px;
    color: var(--ink-faint);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .e-display {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 4px;
  }
  .e-value {
    font-size: 76px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--primary);
  }
  .e-label {
    font-size: 18px;
    font-weight: 400;
    color: var(--ink-faint);
    letter-spacing: -0.01em;
  }

  .e-bar {
    margin: 16px 0 4px;
    height: 2px;
    background: var(--line);
    position: relative;
    overflow: hidden;
  }
  .e-bar-fill {
    position: absolute;
    left: 0; top: 0;
    height: 100%;
    background: var(--primary);
    transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .e-scale {
    display: flex;
    justify-content: space-between;
    font-size: 9px;
    font-weight: 600;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
  }

  .e-desc {
    margin-top: 16px;
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.6;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--rule);
  }

  .types-section { margin-top: 24px; }
  .types-title {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .type-card {
    border-top: 1px solid var(--rule);
    padding: 14px 0;
    transition: all 0.3s ease;
    opacity: 0.4;
  }
  .type-card.active { opacity: 1; }
  .type-card.primary { opacity: 1; }
  .type-card.primary .type-num {
    background: var(--primary);
    color: #ffffff;
    border-color: var(--primary);
  }
  .type-card.primary .type-name { color: var(--primary); }

  .type-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 4px;
  }
  .type-num {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 3px 7px;
    border: 1px solid var(--ink);
    color: var(--ink);
    transition: all 0.3s;
  }
  .type-name {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .type-name .han {
    color: var(--ink-faint);
    font-size: 12px;
    font-weight: 400;
    margin-left: 6px;
  }
  .type-score {
    margin-left: auto;
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }
  .type-card.active .type-score { color: var(--secondary); }
  .type-card.primary .type-score { color: var(--primary); font-weight: 700; }
  .type-desc {
    font-size: 12px;
    color: var(--ink-faint);
    line-height: 1.5;
  }

  .prescription {
    margin-top: 28px;
    padding: 22px;
    background: var(--primary);
    color: #ffffff;
  }
  .presc-label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 8px;
  }
  .presc-title {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  .presc-body {
    font-size: 13px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
  }
  .presc-body strong { color: #ffffff; font-weight: 600; }

  footer {
    border-top: 1px solid var(--rule);
    padding: 28px 48px;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-faint);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>
</head>
<body>

<header>
  <div class="brand">owndo<sup>°</sup></div>
  <div class="meta">Thermal Diagnostic Engine · v1.0</div>
</header>

<section class="patient-bar">
  <div class="patient-label">Patient<br>Profile</div>
  <div class="patient-field">
    <label>이름 / Name</label>
    <input type="text" id="p-name" placeholder="이지연">
  </div>
  <div class="patient-field">
    <label>나이 / Age</label>
    <input type="number" id="p-age" placeholder="29" min="0" max="120">
  </div>
  <div class="patient-field gender">
    <label>성별 / Gender</label>
    <select id="p-gender">
      <option value="">선택</option>
      <option value="여성">여성</option>
      <option value="남성">남성</option>
      <option value="기타">기타</option>
    </select>
  </div>
</section>

<section class="console">

  <div class="panel">
    <div class="panel-label">Step 01 · Input</div>
    <div class="panel-title">열화상 온도값</div>

    <div class="input-row">
      <div class="input-group">
        <label>T_L</label>
        <div class="desc">좌측 평균</div>
        <div class="input-wrap">
          <input type="number" id="tl" value="36.8" step="0.1" min="32" max="40">
          <span class="unit">°C</span>
        </div>
        <div class="slider-wrap">
          <input type="range" data-target="tl" min="32" max="40" step="0.1" value="36.8">
        </div>
      </div>
      <div class="input-group">
        <label>T_R</label>
        <div class="desc">우측 평균</div>
        <div class="input-wrap">
          <input type="number" id="tr" value="35.0" step="0.1" min="32" max="40">
          <span class="unit">°C</span>
        </div>
        <div class="slider-wrap">
          <input type="range" data-target="tr" min="32" max="40" step="0.1" value="35.0">
        </div>
      </div>
    </div>

    <div class="input-row">
      <div class="input-group">
        <label>T_U</label>
        <div class="desc">상체 평균</div>
        <div class="input-wrap">
          <input type="number" id="tu" value="37.1" step="0.1" min="32" max="40">
          <span class="unit">°C</span>
        </div>
        <div class="slider-wrap">
          <input type="range" data-target="tu" min="32" max="40" step="0.1" value="37.1">
        </div>
      </div>
      <div class="input-group">
        <label>T_D</label>
        <div class="desc">하체 평균</div>
        <div class="input-wrap">
          <input type="number" id="td" value="34.8" step="0.1" min="32" max="40">
          <span class="unit">°C</span>
        </div>
        <div class="slider-wrap">
          <input type="range" data-target="td" min="32" max="40" step="0.1" value="34.8">
        </div>
      </div>
    </div>

    <div class="input-row">
      <div class="input-group">
        <label>T_S</label>
        <div class="desc">표면 평균</div>
        <div class="input-wrap">
          <input type="number" id="ts" value="36.0" step="0.1" min="32" max="40">
          <span class="unit">°C</span>
        </div>
        <div class="slider-wrap">
          <input type="range" data-target="ts" min="32" max="40" step="0.1" value="36.0">
        </div>
      </div>
      <div class="input-group">
        <label>T_C</label>
        <div class="desc">심부 추정</div>
        <div class="input-wrap">
          <input type="number" id="tc" value="35.8" step="0.1" min="32" max="40">
          <span class="unit">°C</span>
        </div>
        <div class="slider-wrap">
          <input type="range" data-target="tc" min="32" max="40" step="0.1" value="35.8">
        </div>
      </div>
    </div>

    <div class="presets">
      <div class="panel-label">Preset Cases</div>
      <div class="preset-btns">
        <button class="preset-btn" data-preset="jiyeon">
          <span>이지연 — 29세 직장인 (복합형)</span><span class="arrow">↗</span>
        </button>
        <button class="preset-btn" data-preset="balanced">
          <span>균형 상태 — Original Degree°</span><span class="arrow">↗</span>
        </button>
        <button class="preset-btn" data-preset="lr">
          <span>좌우한열 (TYPE 01)</span><span class="arrow">↗</span>
        </button>
        <button class="preset-btn" data-preset="ud">
          <span>상열하한 (TYPE 02)</span><span class="arrow">↗</span>
        </button>
        <button class="preset-btn" data-preset="sc">
          <span>표열이한 (TYPE 03)</span><span class="arrow">↗</span>
        </button>
        <button class="preset-btn" data-preset="def">
          <span>허한 (TYPE 04)</span><span class="arrow">↗</span>
        </button>
      </div>
    </div>
  </div>

  <div class="viz">
    <div class="viz-label">Layer 01 — Form  ·  Layer 02 — Gradient</div>
    <div class="stage">
      <svg id="ellipse-svg" viewBox="-100 -100 200 200" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="grad-default" x1="50%" y1="0%" x2="50%" y2="100%">
            <stop offset="0%" stop-color="#7A2624" stop-opacity="0.92"/>
            <stop offset="100%" stop-color="#3a5a7a" stop-opacity="0.75"/>
          </linearGradient>
        </defs>
        <ellipse id="main-ellipse" cx="0" cy="0" rx="80" ry="80"
          fill="url(#grad-default)" stroke="#1f1d1b" stroke-width="0.8"/>
        <circle id="center-dot" cx="0" cy="0" r="2" fill="#1f1d1b" opacity="0.4"/>
      </svg>
    </div>

    <div class="equation">
      <div><span class="lbl">δ_LR</span>= |<span class="var">T_L</span> − <span class="var">T_R</span>| / 2.0 = <span class="num" id="eq-lr">0.900</span></div>
      <div><span class="lbl">δ_UD</span>= |<span class="var">T_U</span> − <span class="var">T_D</span>| / 2.0 = <span class="num" id="eq-ud">1.000</span></div>
      <div><span class="lbl">δ_SC</span>= |<span class="var">T_S</span> − <span class="var">T_C</span>| / 2.0 = <span class="num" id="eq-sc">0.100</span></div>
      <div><span class="lbl">δ_허</span>= max(0, (36.5 − T̄)/2.0) = <span class="num" id="eq-def">0.275</span></div>
      <div style="border-top: 1px solid var(--rule); margin-top: 10px; padding-top: 10px;">
        <span class="lbl">e</span>= min(√(δ²+δ²+δ²)/√3 × (1+δ_허), 0.99)
      </div>
      <div><span class="lbl"></span>= <span class="num" id="eq-e">0.000</span></div>
    </div>
  </div>

  <div class="panel">
    <div class="panel-label">Step 02 · Diagnosis</div>

    <div class="e-display">
      <div class="e-value" id="result-e">0.00</div>
      <div class="e-label">eccentricity</div>
    </div>
    <div class="e-bar">
      <div class="e-bar-fill" id="e-bar-fill" style="width: 0%;"></div>
    </div>
    <div class="e-scale">
      <span>0 · 원</span>
      <span>0.5 · 중간</span>
      <span>1 · 납작</span>
    </div>
    <div class="e-desc" id="e-desc">
      균형에 가까운 상태입니다. Original Degree°에 도달했어요.
    </div>

    <div class="types-section">
      <div class="types-title">Type Match · 5 patterns</div>

      <div class="type-card" data-type="01">
        <div class="type-head">
          <span class="type-num">01</span>
          <span class="type-name">좌우한열<span class="han">左右寒熱</span></span>
          <span class="type-score" id="score-01">0.00</span>
        </div>
        <div class="type-desc">음양 불균형. 가로 장축. 좌우 색차.</div>
      </div>

      <div class="type-card" data-type="02">
        <div class="type-head">
          <span class="type-num">02</span>
          <span class="type-name">수승화강<span class="han">上熱下寒</span></span>
          <span class="type-score" id="score-02">0.00</span>
        </div>
        <div class="type-desc">상열하한. 세로 장축. 위→아래 그라디언트.</div>
      </div>

      <div class="type-card" data-type="03">
        <div class="type-head">
          <span class="type-num">03</span>
          <span class="type-name">표열이한<span class="han">表熱裏寒</span></span>
          <span class="type-score" id="score-03">0.00</span>
        </div>
        <div class="type-desc">표면은 따뜻, 심부는 차가움. 반경 그라디언트.</div>
      </div>

      <div class="type-card" data-type="04">
        <div class="type-head">
          <span class="type-num">04</span>
          <span class="type-name">허한<span class="han">虛寒</span></span>
          <span class="type-score" id="score-04">0.00</span>
        </div>
        <div class="type-desc">전체 저온. 점선 테두리, 낮은 채도.</div>
      </div>

      <div class="type-card" data-type="05">
        <div class="type-head">
          <span class="type-num">05</span>
          <span class="type-name">Original Degree°<span class="han">균형</span></span>
          <span class="type-score" id="score-05">0.00</span>
        </div>
        <div class="type-desc">완전한 원. e = 0. 도달 목표.</div>
      </div>
    </div>

    <div class="prescription">
      <div class="presc-label">Treatment · 뜸 처방</div>
      <div class="presc-title" id="presc-title">Original Degree° 유지</div>
      <div class="presc-body" id="presc-body">
        균형 상태입니다. 정기적 스캔으로 상태를 모니터링하세요.
      </div>
    </div>
  </div>

</section>

<footer>
  <span>Layer 1: Form (e)  ·  Layer 2: Gradient (vector)</span>
  <span>°  =  TEMPERATURE  ∩  ANGLE</span>
</footer>

<script>
const T_REF = 36.5;
const NORM = 2.0;

const COLOR = {
  primary:   '#7A2624',
  secondary: '#954E2B',
  tertiary:  '#4E560F',
  accent:    '#909A30',
  cold:      '#3a5a7a',
  coldSoft:  '#7a96b4',
};

const els = {
  tl: document.getElementById('tl'),
  tr: document.getElementById('tr'),
  tu: document.getElementById('tu'),
  td: document.getElementById('td'),
  ts: document.getElementById('ts'),
  tc: document.getElementById('tc'),
  ellipse: document.getElementById('main-ellipse'),
  centerDot: document.getElementById('center-dot'),
  resultE: document.getElementById('result-e'),
  eBarFill: document.getElementById('e-bar-fill'),
  eDesc: document.getElementById('e-desc'),
  eqLr: document.getElementById('eq-lr'),
  eqUd: document.getElementById('eq-ud'),
  eqSc: document.getElementById('eq-sc'),
  eqDef: document.getElementById('eq-def'),
  eqE: document.getElementById('eq-e'),
  prescTitle: document.getElementById('presc-title'),
  prescBody: document.getElementById('presc-body'),
};

const PRESETS = {
  jiyeon:   { tl: 36.8, tr: 35.0, tu: 37.1, td: 34.8, ts: 36.0, tc: 35.8, name: '이지연', age: 29, gender: '여성' },
  balanced: { tl: 36.5, tr: 36.5, tu: 36.5, td: 36.5, ts: 36.5, tc: 36.5 },
  lr:       { tl: 37.5, tr: 35.5, tu: 36.5, td: 36.5, ts: 36.5, tc: 36.5 },
  ud:       { tl: 36.5, tr: 36.5, tu: 37.7, td: 35.3, ts: 36.5, tc: 36.5 },
  sc:       { tl: 36.5, tr: 36.5, tu: 36.5, td: 36.5, ts: 37.4, tc: 35.6 },
  def:      { tl: 35.0, tr: 34.8, tu: 35.2, td: 34.7, ts: 35.0, tc: 34.9 },
};

function readInputs() {
  return {
    TL: parseFloat(els.tl.value) || 36.5,
    TR: parseFloat(els.tr.value) || 36.5,
    TU: parseFloat(els.tu.value) || 36.5,
    TD: parseFloat(els.td.value) || 36.5,
    TS: parseFloat(els.ts.value) || 36.5,
    TC: parseFloat(els.tc.value) || 36.5,
  };
}

function compute(t) {
  const dLR = Math.abs(t.TL - t.TR) / NORM;
  const dUD = Math.abs(t.TU - t.TD) / NORM;
  const dSC = Math.abs(t.TS - t.TC) / NORM;
  const Tavg = (t.TL + t.TR + t.TU + t.TD) / 4;
  const dDef = Math.max(0, (T_REF - Tavg) / NORM);
  const k = 1 + dDef;
  const magnitude = Math.sqrt(dLR*dLR + dUD*dUD + dSC*dSC);
  const e = Math.min(magnitude / Math.sqrt(3) * k, 0.99);

  const totalAxial = dLR + dUD + dSC || 0.001;
  const score01 = Math.min(dLR / Math.max(totalAxial, 0.5), 1);
  const score02 = Math.min(dUD / Math.max(totalAxial, 0.5), 1);
  const score03 = Math.min(dSC / Math.max(totalAxial, 0.5), 1);
  const score04 = Math.min(dDef * 2, 1);
  const score05 = Math.max(0, 1 - e * 1.5);

  const scores = [
    { id: '01', val: score01, magnitude: dLR },
    { id: '02', val: score02, magnitude: dUD },
    { id: '03', val: score03, magnitude: dSC },
    { id: '04', val: score04, magnitude: dDef },
  ];
  let primary;
  if (e < 0.15) primary = '05';
  else primary = scores.sort((a,b) => b.magnitude - a.magnitude)[0].id;

  return {
    dLR, dUD, dSC, dDef, k, e, Tavg,
    scores: { '01': score01, '02': score02, '03': score03, '04': score04, '05': score05 },
    primary,
  };
}

function getOrientation(c) {
  if (c.primary === '03') return { rotation: 0, isRadial: true };
  if (c.primary === '04') return { rotation: 0, isRadial: false, isDeficient: true };
  if (c.primary === '05') return { rotation: 0, isRadial: false };
  const rotation = c.dLR > c.dUD ? 0 : 90;
  return { rotation, isRadial: false };
}

function buildGradient(t, c, orientation) {
  const svg = document.getElementById('ellipse-svg');
  const oldGrad = svg.querySelector('#grad-dynamic');
  if (oldGrad) oldGrad.remove();

  const ns = 'http://www.w3.org/2000/svg';
  const defs = svg.querySelector('defs');

  if (orientation.isDeficient) {
    const grad = document.createElementNS(ns, 'radialGradient');
    grad.setAttribute('id', 'grad-dynamic');
    grad.setAttribute('cx', '50%'); grad.setAttribute('cy', '50%'); grad.setAttribute('r', '50%');
    grad.innerHTML = `
      <stop offset="0%" stop-color="${COLOR.accent}" stop-opacity="0.30"/>
      <stop offset="100%" stop-color="${COLOR.tertiary}" stop-opacity="0.40"/>
    `;
    defs.appendChild(grad);
    return 'url(#grad-dynamic)';
  }

  if (c.primary === '05') {
    const grad = document.createElementNS(ns, 'radialGradient');
    grad.setAttribute('id', 'grad-dynamic');
    grad.setAttribute('cx', '50%'); grad.setAttribute('cy', '50%'); grad.setAttribute('r', '60%');
    grad.innerHTML = `
      <stop offset="0%" stop-color="${COLOR.secondary}" stop-opacity="0.92"/>
      <stop offset="100%" stop-color="${COLOR.primary}" stop-opacity="0.95"/>
    `;
    defs.appendChild(grad);
    return 'url(#grad-dynamic)';
  }

  if (orientation.isRadial) {
    const grad = document.createElementNS(ns, 'radialGradient');
    grad.setAttribute('id', 'grad-dynamic');
    grad.setAttribute('cx', '50%'); grad.setAttribute('cy', '50%'); grad.setAttribute('r', '55%');
    const surfaceHotter = (t.TS - t.TC) > 0;
    if (surfaceHotter) {
      grad.innerHTML = `
        <stop offset="0%" stop-color="${COLOR.cold}" stop-opacity="0.65"/>
        <stop offset="55%" stop-color="${COLOR.secondary}" stop-opacity="0.75"/>
        <stop offset="100%" stop-color="${COLOR.primary}" stop-opacity="0.92"/>
      `;
    } else {
      grad.innerHTML = `
        <stop offset="0%" stop-color="${COLOR.primary}" stop-opacity="0.92"/>
        <stop offset="55%" stop-color="${COLOR.secondary}" stop-opacity="0.75"/>
        <stop offset="100%" stop-color="${COLOR.cold}" stop-opacity="0.65"/>
      `;
    }
    defs.appendChild(grad);
    return 'url(#grad-dynamic)';
  }

  const grad = document.createElementNS(ns, 'linearGradient');
  grad.setAttribute('id', 'grad-dynamic');

  const gx = (t.TL - t.TR) / NORM;
  const gy = (t.TU - t.TD) / NORM;

  let x1, y1, x2, y2;
  if (Math.abs(gx) > Math.abs(gy)) {
    x1='0%'; y1='50%'; x2='100%'; y2='50%';
    if (gx > 0) {
      grad.innerHTML = `<stop offset="0%" stop-color="${COLOR.primary}" stop-opacity="0.92"/>
                        <stop offset="50%" stop-color="${COLOR.secondary}" stop-opacity="0.78"/>
                        <stop offset="100%" stop-color="${COLOR.cold}" stop-opacity="0.72"/>`;
    } else {
      grad.innerHTML = `<stop offset="0%" stop-color="${COLOR.cold}" stop-opacity="0.72"/>
                        <stop offset="50%" stop-color="${COLOR.secondary}" stop-opacity="0.78"/>
                        <stop offset="100%" stop-color="${COLOR.primary}" stop-opacity="0.92"/>`;
    }
  } else {
    x1='50%'; y1='0%'; x2='50%'; y2='100%';
    if (gy > 0) {
      grad.innerHTML = `<stop offset="0%" stop-color="${COLOR.primary}" stop-opacity="0.92"/>
                        <stop offset="50%" stop-color="${COLOR.secondary}" stop-opacity="0.78"/>
                        <stop offset="100%" stop-color="${COLOR.cold}" stop-opacity="0.72"/>`;
    } else {
      grad.innerHTML = `<stop offset="0%" stop-color="${COLOR.cold}" stop-opacity="0.72"/>
                        <stop offset="50%" stop-color="${COLOR.secondary}" stop-opacity="0.78"/>
                        <stop offset="100%" stop-color="${COLOR.primary}" stop-opacity="0.92"/>`;
    }
  }
  grad.setAttribute('x1', x1); grad.setAttribute('y1', y1);
  grad.setAttribute('x2', x2); grad.setAttribute('y2', y2);
  defs.appendChild(grad);
  return 'url(#grad-dynamic)';
}

function eccDescription(e) {
  if (e < 0.1) return '균형에 가까운 상태입니다. Original Degree°에 도달했어요.';
  if (e < 0.3) return '가벼운 불균형. 일상 관리로 회복 가능한 범위입니다.';
  if (e < 0.55) return '중간 정도의 불균형. 정기적인 뜸 시술이 권장됩니다.';
  if (e < 0.8) return '꽤 찌그러진 상태. 집중 케어가 필요한 단계입니다.';
  return '심한 불균형. 즉각적인 처방이 필요합니다.';
}

function getPrescription(c, t) {
  switch (c.primary) {
    case '01':
      return {
        title: '음양 균형 회복',
        body: t.TL > t.TR
          ? '<strong>오른쪽이 더 차갑습니다.</strong> 우측 견정·곡지·합곡 혈자리에 뜸을 시술해 좌우 균형을 회복합니다.'
          : '<strong>왼쪽이 더 차갑습니다.</strong> 좌측 견정·곡지·합곡 혈자리에 뜸을 시술해 좌우 균형을 회복합니다.',
      };
    case '02':
      return {
        title: '수승화강 회복',
        body: '<strong>상열하한 상태.</strong> 용천·족삼리·관원 혈자리에 뜸을 시술합니다. 하체를 데우면 상부의 열이 자연히 하강합니다.',
      };
    case '03':
      return {
        title: '심부 침투 시술',
        body: '<strong>표면은 따뜻하나 심부가 차갑습니다.</strong> 4~5cm 심부까지 침투하는 뜸 시술이 핵심입니다. 신유·명문 혈자리.',
      };
    case '04':
      return {
        title: '기혈 보충',
        body: '<strong>전체적인 에너지 부족.</strong> 관원·기해·중완 혈자리에 장시간 뜸을 시술해 기혈을 보충합니다. 회복엔 시간이 필요합니다.',
      };
    default:
      return {
        title: 'Original Degree° 유지',
        body: '균형 상태입니다. 정기적 스캔으로 상태를 모니터링하세요.',
      };
  }
}

function update() {
  const t = readInputs();
  const c = compute(t);
  const orientation = getOrientation(c);

  els.eqLr.textContent = c.dLR.toFixed(3);
  els.eqUd.textContent = c.dUD.toFixed(3);
  els.eqSc.textContent = c.dSC.toFixed(3);
  els.eqDef.textContent = c.dDef.toFixed(3);
  els.eqE.textContent = c.e.toFixed(3);

  els.resultE.textContent = c.e.toFixed(2);
  els.eBarFill.style.width = (c.e * 100) + '%';
  els.eDesc.textContent = eccDescription(c.e);

  ['01','02','03','04','05'].forEach(id => {
    const card = document.querySelector(`.type-card[data-type="${id}"]`);
    const score = document.getElementById(`score-${id}`);
    const val = c.scores[id];
    score.textContent = val.toFixed(2);
    card.classList.remove('active', 'primary');
    if (val > 0.3) card.classList.add('active');
    if (id === c.primary) card.classList.add('primary');
  });

  const a = 80;
  const ratio = Math.sqrt(Math.max(0, 1 - c.e * c.e));
  const b = a * ratio;

  let rx, ry;
  if (orientation.rotation === 90) { rx = b; ry = a; }
  else { rx = a; ry = b; }

  if (orientation.isDeficient) { rx = a * 0.85; ry = a * 0.85; }
  if (orientation.isRadial) { rx = a * 0.92; ry = a * 0.92; }

  els.ellipse.setAttribute('rx', rx);
  els.ellipse.setAttribute('ry', ry);

  if (orientation.isDeficient) {
    els.ellipse.setAttribute('stroke-dasharray', '3 3');
    els.ellipse.setAttribute('stroke', COLOR.accent);
    els.ellipse.setAttribute('stroke-width', '0.8');
  } else {
    els.ellipse.setAttribute('stroke-dasharray', 'none');
    els.ellipse.setAttribute('stroke', '#1f1d1b');
    els.ellipse.setAttribute('stroke-width', '0.8');
  }

  const fillUrl = buildGradient(t, c, orientation);
  els.ellipse.setAttribute('fill', fillUrl);
  els.centerDot.setAttribute('opacity', c.primary === '05' ? '0.8' : '0.3');

  const presc = getPrescription(c, t);
  els.prescTitle.textContent = presc.title;
  els.prescBody.innerHTML = presc.body;
}

['tl','tr','tu','td','ts','tc'].forEach(id => {
  const numInput = document.getElementById(id);
  const slider = document.querySelector(`input[data-target="${id}"]`);
  numInput.addEventListener('input', (e) => {
    if (slider) slider.value = e.target.value;
    update();
  });
  slider.addEventListener('input', (e) => {
    numInput.value = e.target.value;
    update();
  });
});

document.querySelectorAll('.preset-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const preset = PRESETS[btn.dataset.preset];
    if (!preset) return;
    ['tl','tr','tu','td','ts','tc'].forEach(key => {
      if (preset[key] !== undefined) {
        const numInput = document.getElementById(key);
        const slider = document.querySelector(`input[data-target="${key}"]`);
        if (numInput) numInput.value = preset[key];
        if (slider) slider.value = preset[key];
      }
    });
    if (preset.name !== undefined)   document.getElementById('p-name').value   = preset.name;
    if (preset.age !== undefined)    document.getElementById('p-age').value    = preset.age;
    if (preset.gender !== undefined) document.getElementById('p-gender').value = preset.gender;
    update();
  });
});

update();
</script>

</body>
</html>
